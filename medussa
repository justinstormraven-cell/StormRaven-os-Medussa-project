<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medussa Project: WASI Integration Console</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Chosen Palette: Medussa Cyber-Clinical
         Background: Slate-50 (Neutral, professional)
         Primary: Indigo-600 (Logical flow)
         Secondary: Emerald-600 (Security/Success)
         Highlight: Amber-500 (Audit/Warnings)
    -->

    <!-- Application Structure Plan:
         Designed as a 'Systems Management Console' for the Medussa Project.
         The app translates the text-heavy blueprint into a functional dashboard:
         1. Architecture Gate: Interactive tab system to visualize Midgard vs Asgard residency.
         2. Module Registry: Grid-based cards for the core technical components.
         3. Audit Monitor: Simulation of the 'Mjolnir Pipeline' to demonstrate the '0% Error' mandate logic.
         The structure was chosen to emphasize the 'Hybrid' nature of the OS, showing how WASI (Guest) interacts with Linux (Host).
    -->

    <!-- Visualization & Content Choices:
         - Stability Comparison (Bar Chart): Visualizes the '0% Error' goal vs legacy OS benchmarks.
         - Verification Progress (Interactive List): Shows the Mjolnir Audit steps with dynamic status updates.
         - NO SVG/Mermaid: Used CSS borders and grid layouts to create architectural diagrams.
    -->

    <!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;700&display=swap');

        body { font-family: 'Inter', sans-serif; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            height: 300px;
            max-height: 400px;
        }

        .gate-active {
            border-color: #4f46e5;
            background-color: #eef2ff;
            color: #3730a3;
        }

        .status-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .5; }
        }

        .audit-step-done {
            background-color: #ecfdf5;
            border-left: 4px solid #10b981;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">

    <div class="max-w-6xl mx-auto p-4 md:p-8">
        <!-- Header -->
        <header class="mb-8 border-b border-slate-200 pb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <div class="flex items-center space-x-2">
                    <div class="h-3 w-3 bg-indigo-600 rounded-full"></div>
                    <h1 class="text-2xl font-bold tracking-tight font-mono">MEDUSSA_PROJECT_CORE</h1>
                </div>
                <p class="text-slate-500 text-sm mt-1 uppercase tracking-widest">WASI / Linux Hybrid Architecture</p>
            </div>
            <div class="bg-white border border-slate-200 px-4 py-2 rounded shadow-sm">
                <div class="text-[10px] text-slate-400 font-bold uppercase">System Integrity</div>
                <div class="flex items-center space-x-2">
                    <span class="text-emerald-600 font-mono font-bold">0.00% ERR</span>
                    <span class="h-2 w-2 rounded-full bg-emerald-500 status-pulse"></span>
                </div>
            </div>
        </header>

        <!-- Executive Summary Section -->
        <section class="mb-12">
            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <h2 class="text-lg font-bold mb-4 flex items-center">
                    <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-xs mr-3">01</span>
                    Executive Summary
                </h2>
                <p class="text-slate-600 leading-relaxed">
                    The Medussa Project represents the 'Third Way' of operating system design. By merging the <strong>Linux Kernel (Host)</strong> with a high-performance <strong>WASI Runtime (Guest)</strong>, we achieve a hybrid environment where tactical logic is isolated within capability-based sandboxes, while the host provides raw system-level power.
                </p>
            </div>
        </section>

        <!-- Architecture Selector (Dual-Gated Model) -->
        <section class="mb-12">
            <h2 class="text-lg font-bold mb-6 flex items-center">
                <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-xs mr-3">02</span>
                Theoretical Architecture: The Dual-Gated Model
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <button id="btn-midgard" onclick="app.showLayer('midgard')" class="p-6 text-left border-2 border-transparent bg-white rounded-xl shadow-sm transition-all gate-active">
                    <h3 class="font-bold text-lg">Midgard Layer</h3>
                    <p class="text-xs text-slate-400 font-mono mt-1">VOLATILE / WASI RUNTIME</p>
                    <p class="text-sm mt-3 text-slate-600">All WASI modules run in RAM-only environments. Direct host access is restricted by the Heketa Bridge.</p>
                </button>
                <button id="btn-asgard" onclick="app.showLayer('asgard')" class="p-6 text-left border-2 border-transparent bg-white rounded-xl shadow-sm transition-all">
                    <h3 class="font-bold text-lg">Asgard Layer</h3>
                    <p class="text-xs text-slate-400 font-mono mt-1">KERNEL / LINUX HOST</p>
                    <p class="text-sm mt-3 text-slate-600">A custom Linux Kernel Module (LKM) intercepts syscalls and maps them to sanitized host operations.</p>
                </button>
            </div>

            <!-- Architecture Logic Viz (CSS Only) -->
            <div class="bg-slate-900 p-8 rounded-xl relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10 font-mono text-4xl text-white">WASI_V1</div>
                <div class="flex flex-col items-center space-y-4">
                    <!-- Midgard Node -->
                    <div id="viz-midgard" class="w-full max-w-md bg-indigo-500 text-white p-4 rounded text-center font-mono text-sm border-2 border-indigo-400 shadow-lg transition-opacity duration-300">
                        [ MIDGARD: WASI SANDBOX ]
                    </div>
                    <!-- The Bridge -->
                    <div class="flex flex-col items-center py-2">
                        <div class="h-8 w-1 bg-slate-700"></div>
                        <div class="bg-emerald-500 text-slate-900 px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-tighter">Heketa_Bridge</div>
                        <div class="h-8 w-1 bg-slate-700"></div>
                    </div>
                    <!-- Asgard Node -->
                    <div id="viz-asgard" class="w-full max-w-md bg-slate-800 text-slate-300 p-4 rounded text-center font-mono text-sm border-2 border-slate-700 opacity-40 transition-opacity duration-300">
                        [ ASGARD: LINUX KERNEL ]
                    </div>
                </div>
            </div>
        </section>

        <!-- Component Grid -->
        <section class="mb-12">
            <h2 class="text-lg font-bold mb-6 flex items-center">
                <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-xs mr-3">03</span>
                Core Module Registry
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Heketa -->
                <div class="bg-white p-5 rounded-lg border border-slate-200 shadow-sm hover:border-indigo-300 transition-colors">
                    <div class="text-xs font-mono text-indigo-600 mb-2">INTEGRATION_BRIDGE</div>
                    <h3 class="font-bold text-slate-900">Heketa Bridge</h3>
                    <p class="text-sm text-slate-500 mt-2 italic">Syscall Interceptor</p>
                    <p class="text-sm text-slate-600 mt-3">A Rust-based wrapper for wasmtime that enforces POSIX compliance within the sandbox.</p>
                </div>
                <!-- Sleipnir -->
                <div class="bg-white p-5 rounded-lg border border-slate-200 shadow-sm hover:border-indigo-300 transition-colors">
                    <div class="text-xs font-mono text-indigo-600 mb-2">SCHEDULER_DAEMON</div>
                    <h3 class="font-bold text-slate-900">Sleipnir Scheduler</h3>
                    <p class="text-sm text-slate-500 mt-2 italic">Process Orchestrator</p>
                    <p class="text-sm text-slate-600 mt-3">A real-time scheduler prioritizing WASI threads based on formal verification scores.</p>
                </div>
                <!-- Heimdall -->
                <div class="bg-white p-5 rounded-lg border border-slate-200 shadow-sm hover:border-indigo-300 transition-colors">
                    <div class="text-xs font-mono text-indigo-600 mb-2">HARDWARE_GUARD</div>
                    <h3 class="font-bold text-slate-900">Heimdall Guard</h3>
                    <p class="text-sm text-slate-500 mt-2 italic">Security Sentinel</p>
                    <p class="text-sm text-slate-600 mt-3">Hardware-level memory isolation using Intel VT-x or AMD-V for the WASI runtime.</p>
                </div>
            </div>
        </section>

        <!-- 0% Error Mandate (Mjolnir Audit) -->
        <section class="mb-12">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Audit Pipeline UI -->
                <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                    <h2 class="text-lg font-bold mb-6 flex items-center">
                        <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-xs mr-3">04</span>
                        Mjolnir Audit Pipeline
                    </h2>
                    <div class="space-y-4">
                        <div id="step-1" class="p-4 bg-slate-50 border border-slate-200 rounded-lg transition-all">
                            <div class="flex justify-between items-center">
                                <span class="font-bold text-sm">Step 1: Static Analysis</span>
                                <span class="text-[10px] font-mono text-emerald-600">PASSED</span>
                            </div>
                            <p class="text-xs text-slate-500 mt-1">Mandatory Clippy and ShellCheck validation at 'Deny' level.</p>
                        </div>
                        <div id="step-2" class="p-4 bg-slate-50 border border-slate-200 rounded-lg transition-all">
                            <div class="flex justify-between items-center">
                                <span class="font-bold text-sm">Step 2: Formal Verification</span>
                                <span class="text-[10px] font-mono text-amber-600 animate-pulse">VERIFYING...</span>
                            </div>
                            <p class="text-xs text-slate-500 mt-1">Critical path logic (memory allocation) verified using Kani or TLA+.</p>
                        </div>
                        <div id="step-3" class="p-4 bg-slate-50 border border-slate-200 rounded-lg transition-all">
                            <div class="flex justify-between items-center">
                                <span class="font-bold text-sm">Step 3: Automated Fuzzing</span>
                                <span class="text-[10px] font-mono text-slate-400">WAITING</span>
                            </div>
                            <p class="text-xs text-slate-500 mt-1">24-hour stress testing of the WASI-to-Host bridge.</p>
                        </div>
                    </div>
                    <button onclick="app.runAudit()" class="mt-6 w-full py-2 bg-indigo-600 text-white font-bold rounded text-sm hover:bg-indigo-700 transition-colors">INITIATE MJOLNIR AUDIT</button>
                </div>

                <!-- Error Rate Chart -->
                <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                    <h3 class="text-sm font-bold text-slate-400 uppercase mb-4 tracking-widest">Reliability Benchmarks</h3>
                    <div class="chart-container">
                        <canvas id="reliabilityChart"></canvas>
                    </div>
                    <p class="text-[10px] text-slate-400 mt-4 italic text-center">
                        Design Note: If a module fails, the sandbox is instantly purged and re-instantiated, maintaining a 0% persistent error state.
                    </p>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="mt-12 pt-8 border-t border-slate-200 text-center">
            <p class="text-xs text-slate-400 font-mono">MEDUSSA_BLUEPRINT // SESSION_SR_OS // VER_09.2025</p>
        </footer>
    </div>

    <script>
        const app = {
            init: function() {
                this.initChart();
                console.log("Medussa Console Online.");
            },

            showLayer: function(layer) {
                const midBtn = document.getElementById('btn-midgard');
                const asgBtn = document.getElementById('btn-asgard');
                const midViz = document.getElementById('viz-midgard');
                const asgViz = document.getElementById('viz-asgard');

                if (layer === 'midgard') {
                    midBtn.classList.add('gate-active');
                    asgBtn.classList.remove('gate-active');
                    midViz.style.opacity = '1';
                    asgViz.style.opacity = '0.4';
                } else {
                    asgBtn.classList.add('gate-active');
                    midBtn.classList.remove('gate-active');
                    asgViz.style.opacity = '1';
                    midViz.style.opacity = '0.4';
                }
            },

            runAudit: function() {
                const s2 = document.getElementById('step-2');
                const s3 = document.getElementById('step-3');

                // Simulate formal verification finishing
                setTimeout(() => {
                    s2.classList.add('audit-step-done');
                    s2.querySelector('.font-mono').innerText = 'PASSED (0 ERROR PROVEN)';
                    s2.querySelector('.font-mono').classList.remove('animate-pulse', 'text-amber-600');
                    s2.querySelector('.font-mono').classList.add('text-emerald-600');

                    // Start fuzzing
                    s3.querySelector('.font-mono').innerText = 'FUZZING...';
                    s3.querySelector('.font-mono').classList.remove('text-slate-400');
                    s3.querySelector('.font-mono').classList.add('text-amber-600', 'animate-pulse');
                }, 1500);
            },

            initChart: function() {
                const ctx = document.getElementById('reliabilityChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['Legacy Monolithic', 'Microkernel', 'Medussa (Hybrid WASI)'],
                        datasets: [{
                            label: 'System Error Probability (%)',
                            data: [12.4, 4.2, 0.0],
                            backgroundColor: [
                                '#cbd5e1',
                                '#818cf8',
                                '#10b981'
                            ],
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: { display: true, text: 'Failure Rate %' }
                            }
                        }
                    }
                });
            }
        };

        window.onload = () => app.init();
    </script>
</body>
</html>
